---
interface Props {
  title: string;
  tagline: string;
  image: string;
  techStack: string[];
  liveUrl?: string;
  githubUrl?: string;
  githubLabel?: string;
  imagePosition?: string;
}

const { title, tagline, image, techStack, liveUrl, githubUrl, githubLabel = 'View on GitHub', imagePosition = 'object-top' } = Astro.props;
---

<a class="text-lightpurple font-bold hover:underline" href="/">&larr; Back to Portfolio</a>
<div class="mb-12 mt-6">
  <img
    src={image}
    alt={title}
    class:list={[`w-full h-48 md:h-72 lg:h-80 object-cover rounded-lg shadow-2xl cursor-zoom-in`, imagePosition]}
    data-lightbox
  />
  <div class="mt-6">
    <h1 class="text-3xl lg:text-4xl font-bold text-lightpurple mb-2">
      {title}
    </h1>
    <p class="text-lg lg:text-xl text-gray-300 mb-4">{tagline}</p>
    <div class="flex flex-wrap gap-2 mb-4">
      {techStack.map((tech) => (
        <span class="text-sm bg-medpurple/60 text-lightpurple px-3 py-1 rounded">
          {tech}
        </span>
      ))}
    </div>
    <div class="flex gap-4">
      {liveUrl && (
        <a
          href={liveUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-lightblue font-semibold hover:underline"
        >
          Visit Live Site &rarr;
        </a>
      )}
      {githubUrl && (
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-lightblue font-semibold hover:underline"
        >
          {githubLabel} &rarr;
        </a>
      )}
    </div>
  </div>
</div>
