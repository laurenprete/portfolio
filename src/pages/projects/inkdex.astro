---
import Base from '@/templates/Base.astro';
import ProjectHero from '@/components/ProjectHero.astro';
import FeatureBlock from '@/components/FeatureBlock.astro';
import { AppConfig } from '@/utils/AppConfig';

const title = `GPI InkDex | ${AppConfig.title}`;
const description = 'AI-powered SEO audit and content generation tool for Shopify';
---

<Base head={{ title, description }}>
  <div class="max-w-4xl mx-auto">
    <ProjectHero
      title="GPI InkDex"
      tagline="AI-powered SEO audit and content generation tool for Shopify"
      image="/assets/images/projects/inkdex-hero.png"
      techStack={['React', 'Hono', 'Claude API', 'Tailwind CSS', 'Amplify']}
    />

    <section class="mb-12">
      <h2 class="text-2xl font-bold text-lightpurple mb-4">The Story</h2>
      <p class="text-gray-200 leading-relaxed mb-4">
        GPI Supplies is a Shopify-based retailer with hundreds of product collections.
        Each collection page needs optimized SEO metadata, a well-written intro, and
        targeted keywords to rank well in search. Manually auditing and writing that
        content across hundreds of pages is slow and inconsistent.
      </p>
      <p class="text-gray-200 leading-relaxed mb-4">
        InkDex solves this by scanning every collection in the store and scoring its
        SEO readiness on a 0-100 scale across six categories: meta title, meta description,
        brief intro, content blocks, keyword coverage, and technical hygiene. Where content
        is weak or missing, the tool generates optimized suggestions using Claude, then
        writes approved changes directly back to Shopify via the Admin GraphQL API.
      </p>
      <p class="text-gray-200 leading-relaxed">
        Built with React and Vite on the frontend, a Hono API backend, and deployed
        on AWS Amplify.
      </p>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold text-lightpurple mb-6">Features</h2>

      <FeatureBlock
        title="SEO Scoring Dashboard"
        description="Every collection gets a score across six weighted categories. Color-coded badges make it easy to spot weak pages at a glance. Smart validations detect placeholder text, flag outdated brand names, and catch messaging mismatches between equipment and supplies collections. The table is searchable, sortable, and filterable by collection type or score range."
        image="/assets/images/projects/inkdex-dashboard.png"
        imageAlt="InkDex SEO scoring dashboard with collection scores"
      />

      <FeatureBlock
        title="AI Content Suggestions"
        description="Generate three optimized options per field using Claude. The prompts are context-aware, incorporating product data, collection type, and target keywords. Suggestions follow character limits, avoid generic copy, and adapt tone for equipment vs. supplies pages. One click to apply."
        image="/assets/images/projects/inkdex-suggestions.png"
        imageAlt="InkDex AI-generated SEO content suggestions"
        reverse={true}
      />

      <FeatureBlock
        title="Direct Shopify Sync"
        description="Edits save directly to Shopify in one action, updating both standard SEO fields and custom metafields. Real-time validation ensures titles, descriptions, and intros meet length and quality requirements before anything is published."
        image="/assets/images/projects/inkdex-editor.png"
        imageAlt="InkDex collection editor with Shopify sync"
      />
    </section>

    <a class="text-lightpurple font-bold hover:underline" href="/">&larr; Back to Portfolio</a>
  </div>
</Base>
